<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="#FFF5F8">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ayarlar ✨"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#AD1457"
        android:layout_marginBottom="40dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSettingsLogin"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="Bulut Yedekleme İçin Giriş Yap"
        android:visibility="gone"
        app:cornerRadius="12dp"
        android:backgroundTint="#AD1457" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardAccountInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="#FFFFFF">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hesap Bilgileri"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#AD1457"
                android:layout_marginBottom="8dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#FCE4EC"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvUserStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="yakuphan@gmail.com"
                android:textSize="16sp"
                android:textColor="#424242"
                android:layout_marginBottom="24dp"
                app:drawableStartCompat="@android:drawable/ic_dialog_email"
                android:drawablePadding="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSettingsLogout"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Hesaptan Çıkış Yap"
                android:textColor="#D32F2F"
                app:strokeColor="#D32F2F"
                app:cornerRadius="12dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>